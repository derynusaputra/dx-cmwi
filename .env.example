# ============================================
# CMWI Docker Deployment Configuration
# ============================================
# Copy file ini menjadi .env lalu isi sesuai environment Anda:
#   cp .env.example .env

# IP address PC server di jaringan lokal
# Cek via: ipconfig (Windows) atau ip addr (Linux)
SERVER_IP=192.168.x.x

# Custom local domain (opsional)
# Karyawan perlu tambahkan di file hosts (lihat README-DEPLOY.md)
APP_DOMAIN=qc.cmwi.local

# Port HTTPS & HTTP
NGINX_PORT=8443
NGINX_HTTP_PORT=8880

# URL lengkap aplikasi (HTTPS)
# Sesuaikan domain/IP dan port di atas
APP_URL=https://qc.cmwi.local:8443

# PostgreSQL (Docker Container)
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=db_cmwi
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT Secret
JWT_SECRET=your-secret-key
