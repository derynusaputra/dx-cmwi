# ============================================
# CMWI Docker Deployment Configuration
# ============================================

# IP address PC server di jaringan lokal
# Cek via: ipconfig (Windows) atau ip addr (Linux)
SERVER_IP=192.168.0.119

# Custom local domain
# Karyawan perlu tambahkan di file hosts (lihat README-DEPLOY.md)
APP_DOMAIN=qc.cmwi.local

# Port HTTPS (default 443)
# Ubah jika port 443 sudah terpakai di server
NGINX_PORT=8443
NGINX_HTTP_PORT=8880

# URL lengkap aplikasi (HTTPS)
# Jika NGINX_PORT=443 -> https://qc.cmwi.local
# Jika NGINX_PORT=8443 -> https://qc.cmwi.local:8443
APP_URL=https://qc.cmwi.local:8443

# PostgreSQL (Docker Container)
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=db_cmwi
DB_USERNAME=dery
DB_PASSWORD=apaannih

# DATABASE_URL format (untuk referensi)
# DATABASE_URL=postgresql://dery:apaannih@72.62.125.72:5433/db_bun_halalinmu

# JWT
JWT_SECRET=cmwi-secret-key-2026
